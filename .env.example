# Required: Your Olostep API key
OLOSTEP_API_KEY=your_api_key_here

# Optional: Override the base API URL (defaults to https://api.olostep.com/v1)
# OLOSTEP_BASE_API_URL=https://api.olostep.com/v1

# Optional: API timeout in seconds (defaults to 150)
# OLOSTEP_API_TIMEOUT=150

# Optional: Custom user agent string
# OLOSTEP_USER_AGENT=olostep-node-sdk/0.1.0

# Optional: Path for logging (defaults to null/no logging)
# OLOSTEP_IO_LOG_PATH=./logs
